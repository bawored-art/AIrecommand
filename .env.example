# CoinGecko Demo API Key (무료, 없어도 동작하지만 rate limit이 낮음)
COINGECKO_API_KEY=

# GitHub API Token (선택, 없으면 익명 rate limit 적용 — 60 req/h)
# 300개 코인의 개발 활동을 조회하므로 반드시 발급 권장
GITHUB_TOKEN=

# 유료 온체인 데이터 소스 (Santiment 등). 없으면 자동으로 mock 클라이언트 사용
SANTIMENT_API_KEY=

# CatalystAnalyzer / NewsAnalyzer / RiskAnalyzer 배치 분류용 (Anthropic Claude API)
# 없으면 해당 지표는 추정하지 않고 null + 사유로 결측 처리된다
ANTHROPIC_API_KEY=
